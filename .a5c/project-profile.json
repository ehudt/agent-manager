        "category": "JSON processing"
      },
      {
        "name": "git",
        "category": "Version control with worktree support"
      }
    ]
  },
  "architecture": {
    "pattern": "modular-cli",
    "modules": [
      {
        "name": "agents",
        "path": "lib/agents.sh",
        "description": "Agent lifecycle management"
      },
      {
        "name": "registry",
        "path": "lib/registry.sh",
        "description": "Session metadata persistence"
      },
      {
        "name": "tmux",
        "path": "lib/tmux.sh",
        "description": "tmux wrapper functions"
      },
      {
        "name": "fzf",
        "path": "lib/fzf.sh",
        "description": "Interactive UI and main loop"
      },
      {
        "name": "form",
        "path": "lib/form.sh",
        "description": "tput-based new session form"
      },
      {
        "name": "state",
        "path": "lib/state.sh",
        "description": "Session state detection"
      },
      {
        "name": "config",
        "path": "lib/config.sh",
        "description": "User configuration"
      },
      {
        "name": "sandbox",
        "path": "lib/sandbox.sh",
        "description": "Docker sandbox lifecycle"
      },
      {
        "name": "utils",
        "path": "lib/utils.sh",
        "description": "Shared utilities"
      }
    ],
    "entryPoints": [
      "am"
    ],
    "dataFlow": "am loads lib/* modules. fzf_main() for interactive, cmd_* for direct. Registry JSON <-> tmux <-> pane JSONL."
  },
  "team": [
    {
      "name": "Ehud Tamir",
      "role": "Sole developer",
      "responsibilities": [
        "All development",
        "Architecture",
        "Testing",
        "Operations"
      ]
    },
    {
      "name": "Claude (AI)",
      "role": "AI contributor",
      "responsibilities": [
        "Feature PRs",
        "Documentation",
        "Bug fixes"
      ]
    },
    {
      "name": "Codex (AI)",
      "role": "AI contributor",
      "responsibilities": [
        "Feature PRs"
      ]
    }
  ],
  "workflows": [
    {
      "name": "development",
      "description": "Trunk-based: direct commits to main, PRs for AI changes",
      "steps": [
        "Edit code",
        "bash -n syntax check",
        "tests/test_all.sh",
        "Commit to main"
      ],
      "triggers": [
        "manual"
      ]
    },
    {
      "name": "testing",
      "description": "Parallel bash test execution with tmux isolation",
      "steps": [
        "test_all.sh parallel workers",
        "pytest integration/security/docker",
        "perf_test.sh standalone"
      ],
      "triggers": [
        "manual",
        "CI"
      ]
    },
    {
      "name": "ci-pipeline",
      "description": "GitHub Actions on push/PR",
      "steps": [
        "syntax check",
        "docs sync",
        "test suite",
        "perf benchmark",
        "secrets scan"
      ],
      "triggers": [
        "push to main",
        "pull requests"
      ]
    }
  ],
  "conventions": {
    "naming": {
      "functions": "module_prefix (registry_add, tmux_create_session)",
      "files": "No shebang in lib/*, shebang in am and bin/*",
      "sessions": "am-<6-char-hash>"
    },
    "git": {
      "commitStyle": "Imperative mood, verb-first",
      "branchStrategy": "Trunk-based, PRs for AI only",
      "mergeStrategy": "Direct push, merge for PRs"
    },
    "codeStyle": {
      "errorHandling": "set -euo pipefail in entry point only",
      "output": "stderr for logging, stdout for returns",
      "portability": "sed -E not -r"
    },
    "testingConventions": "tests/test_*.sh sourced by test_all.sh, pytest markers for integration/security/docker",
    "additionalRules": [
      "Use sed -E for portability",
      "SCRIPT_DIR overwritten when sourcing lib/agents.sh",
      "Sandbox containers run as ubuntu user"
    ]
  },
  "painPoints": [
    {
      "id": "pp-sandbox-instability",
      "description": "Sandbox subsystem required continuous rework (66 commits, 21%)",
      "severity": "high",
      "category": "architecture",
      "discoveredVia": "git-analysis",
      "suggestedRemediation": "Better test coverage for sandbox lifecycle"
    },
    {
      "id": "pp-fix-ratio",
      "description": "21.5% of commits are fixes, insufficient pre-commit quality gates",
      "severity": "medium",
      "category": "quality",
      "discoveredVia": "git-analysis",
      "suggestedRemediation": "Automated testing before commit"
    },
    {
      "id": "pp-manual-testing",
      "description": "Manual testing loops for sandbox and form changes are slow and error-prone",
      "severity": "high",
      "category": "testing",
      "discoveredVia": "user-interview",
      "suggestedRemediation": "Automated integration and regression testing"
    },
    {
      "id": "pp-ui-visual-testing",
      "description": "UI/visual testing (timing, visual changes) is manual, slow, unreliable, hard to reproduce",
      "severity": "high",
      "category": "testing",
      "discoveredVia": "user-interview",
      "suggestedRemediation": "Terminal capture testing, tmux pane content assertion framework"
    }
  ],
  "bottlenecks": [
    {
      "id": "bn-sandbox-churn",
      "description": "Sandbox has highest churn with multiple architecture redesigns",
      "impact": "Major time sink",
      "location": "lib/sandbox.sh, sandbox/Dockerfile",
      "frequency": "Continuous"
    },
    {
      "id": "bn-test-isolation",
      "description": "Tests leaked into real tmux sessions and user config",
      "impact": "Developer environment pollution",
      "location": "tests/",
      "frequency": "Periodic"
    }
  ],
  "cicd": {
    "provider": "GitHub Actions",
    "configPaths": [
      ".github/workflows/ci.yml",
      ".github/workflows/secrets.yml"
    ],
    "pipelines": [
      {
        "name": "CI",
        "trigger": "push/PR",
        "stages": [
          "syntax-check",
          "docs-sync",
          "test-suite",
          "perf-test"
        ]
      },
      {
        "name": "Secrets Scan",
        "trigger": "push/PR",
        "stages": [
          "scan-tracked",
          "scan-history"
        ]
      }
    ],
    "babysitterIntegration": {
      "enabled": false
    }
  },
