  ],
  "techStack": {
    "languages": [
      {
        "name": "Bash",
        "version": "4.0+",
        "role": "Primary language for CLI and all modules"
      },
      {
        "name": "Python",
        "version": "3.11+",
        "role": "Integration tests (pytest)"
      }
    ],
    "frameworks": [
      {
        "name": "tmux",
        "version": ">=3.0",
        "category": "Session persistence and multiplexing"
      },
      {
        "name": "fzf",
        "version": ">=0.40",
        "category": "Interactive selection UI"
      },
      {
        "name": "pytest",
        "category": "Python test framework"
      }
    ],
    "databases": [],
    "buildTools": [],
    "packageManagers": [],
    "infrastructure": [
      {
        "name": "Docker",
        "category": "Sandbox container runtime"
      },
