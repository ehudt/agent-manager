{
  "qualityThreshold": 80,
  "testCoverage": 60,
  "linting": {
    "tools": ["shellcheck", "bash -n"],
    "command": "bash -n lib/*.sh am",
    "description": "Syntax check all shell scripts"
  },
  "testing": {
    "commands": ["./tests/test_all.sh", "pytest"],
    "summaryCommand": "./tests/test_all.sh --summary"
  },
  "commitChecks": {
    "syntaxCheck": "bash -n lib/*.sh am",
    "docsSync": true,
    "secretsScan": true
  },
  "deployGates": {
    "testsPass": true,
    "noLintErrors": true
  }
}
