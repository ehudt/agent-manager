#!/usr/bin/env bash
# am - Agent Manager
# A CLI tool for managing multiple AI coding agent sessions

if [[ -z "${BASH_VERSINFO:-}" ]] || (( BASH_VERSINFO[0] < 4 )); then
    echo "am requires bash >= 4.0 (current: ${BASH_VERSION:-unknown})." >&2
    echo "Install a newer bash and ensure it is first in PATH so '/usr/bin/env bash' resolves to it." >&2
    exit 1
fi

set -euo pipefail

# Version
AM_VERSION="0.3.0"

# Determine script directory (resolve symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    AM_SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$AM_SCRIPT_DIR/$SOURCE"
done
AM_SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AM_LIB_DIR="$AM_SCRIPT_DIR/lib"

# Usage information (no dependencies needed)
usage() {
    echo "am - Agent Manager v$AM_VERSION"
    cat <<'EOF'

Manage multiple AI coding agent sessions with an interactive fzf interface.

USAGE:
    am [command] [options]
    am new [options] <directory> [-- extra-args...]

COMMANDS:
    (default)           Open interactive session browser
    list                List all sessions
    new                 Create a new agent session
    send                Send a prompt to a running session
    peek                Show or follow another session's pane output
    attach              Attach to a session by name (exact, prefix, or fuzzy)
    kill                Kill a session
    config              Show or change saved defaults
    status              Show detailed session info
    wait                Block until a session reaches a target state
    interrupt           Send Ctrl-C to an agent pane
    restore             Browse and resume a closed Claude session
    sandbox, sb         Manage sandbox containers and home directory
    install             First-time setup (deps, config, skills, PATH)
    help                Show this help message

OPTIONS FOR 'list':
    --json          Output as JSON

OPTIONS FOR 'new':
    -t, --type      Agent type: claude, codex (saved default applies)
    -n, --name      Custom task description
    -d, --dir       Directory (can also be positional arg)
    -w, --worktree  Enable git worktree isolation (Claude, Codex)
                    Optional: -w <name> to set worktree name (default: am-XXXXXX)
    --sandbox       Run session in Docker sandbox container
    --no-sandbox    Disable sandbox even if enabled by default
    --share SPEC    Extra sandbox bind mount (<host>[:container][:ro|rw])
    --detach        Create the session without attaching
    --print-session Print the created session name to stdout
    --              Pass remaining args to agent (e.g., -- --resume)

OPTIONS FOR 'send':
    Read prompt text from argv or stdin and inject it into the running agent pane.

OPTIONS FOR 'peek':
    --pane <name>   Pane to inspect: agent|shell (default: agent)
    --follow, -f    Stream output continuously
    --lines N       Lines of pane content to include, from the end (default: 50)

OPTIONS FOR 'wait':
    --state <list>  Comma-separated target states (default: waiting_input,waiting_permission,waiting_custom,idle,dead)
    --timeout N     Seconds before giving up (default: 600)
    --json          Print final state as JSON object on exit

OPTIONS FOR 'status':
    --json          Output as JSON (single session or array of all sessions)

KEYBINDINGS (interactive browser):
    Enter           Attach active session or restore inactive session
    Ctrl-N          Create new session (one-page form)
    Ctrl-X          Kill selected active session
    Ctrl-R          Refresh session list
    ?               Show inline help

KEYBINDINGS (inside tmux session):
    Prefix + a      Switch to last am session
    Prefix + n      Open a popup to create a new session
    Prefix + s      Open am browser popup
    Prefix + x      Kill the current am session
    Prefix + d      Detach from session
    Prefix Up/Down  Switch panes (agent/shell)
    :am             Open am browser (tmux command)

EXAMPLES:
    am                              # Open interactive browser
    am new                          # New session in current dir (uses defaults)
    am new ~/code/proj              # New session in specific directory
    am new -t codex ~/code/proj     # New codex session
    am new -n "fix auth" .          # Session with task description
    printf 'Fix auth bug\n' | am new --detach ~/code/proj
    printf 'Run the test suite\n' | am send am-abc123
    am peek am-abc123
    am peek --pane shell --follow am-abc123
    am attach am-abc123             # Attach to session by name
    am kill am-abc123               # Kill specific session
    am sb ps                        # List sandbox containers
    am sb build --no-cache          # Rebuild sandbox image
    am sb enter am-abc123           # Re-enter a running sandbox shell

DEPENDENCIES:
    tmux >= 3.0, fzf >= 0.40, jq, git

CONFIGURATION:
    Sessions stored in: ~/.agent-manager/
    Agent sessions run on the dedicated tmux server/socket: agent-manager
    See README for tmux setup details.
EOF
}

# Handle help/version before loading libs (no deps needed)
case "${1:-}" in
    help|--help|-h)
        usage
        exit 0
        ;;
    version|--version|-v)
        echo "am version $AM_VERSION"
        exit 0
        ;;
esac

# Export AM_LIB_DIR so libs skip dirname subprocesses
export AM_LIB_DIR

# Source core libraries (needed by all commands)
source "$AM_LIB_DIR/utils.sh"
source "$AM_LIB_DIR/config.sh"
source "$AM_LIB_DIR/tmux.sh"
source "$AM_LIB_DIR/registry.sh"

# Fast path: list-internal is called on every browser reload — compiled Go binary
if [[ "${1:-}" == "list-internal" ]]; then
    # Require both executable bit and non-zero size. test_install's fake `go`
    # writes a zero-byte stub at bin/am-list-internal; an exec on that returns
    # empty output and breaks parallel test workers that share the project tree.
    if [[ -x "$AM_SCRIPT_DIR/bin/am-list-internal" && -s "$AM_SCRIPT_DIR/bin/am-list-internal" ]]; then
        exec "$AM_SCRIPT_DIR/bin/am-list-internal"
    fi
    echo "Error: bin/am-list-internal is not built. Run 'make' (or 'am install') to build it." >&2
    exit 1
fi

# Source remaining libraries for interactive commands
source "$AM_LIB_DIR/agents.sh"
source "$AM_LIB_DIR/fzf.sh"

# Lazy-loaders: state.sh, sandbox.sh, form.sh are deferred for faster startup
_ensure_state() { [[ "$(type -t agent_get_state)" == "function" ]] || source "$AM_LIB_DIR/state.sh"; }
_ensure_sandbox() { [[ "$(type -t sandbox_start)" == "function" ]] || source "$AM_LIB_DIR/sandbox.sh"; }
_ensure_form() { [[ "$(type -t _form_run)" == "function" ]] || source "$AM_LIB_DIR/form.sh"; }

# Command: list (plain text or JSON)
cmd_list() {
    local json=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json|-j)
                json=true
                shift
                ;;
            *)
                log_error "Unknown option: $1"
                return 1
                ;;
        esac
    done

    if $json; then
        fzf_list_json
    else
        fzf_list_simple
    fi
}

# Command: browse (interactive fzf session picker — default when no args)
cmd_browse() {
    local result
    result=$(fzf_main)

    if [[ "$result" == $'__RESTORE__\x1f'* ]]; then
        # Parse: __RESTORE__<US>directory<US>session_id
        local directory session_id
        IFS=$'\x1f' read -r _tag directory session_id <<< "$result"
        cmd_restore_internal "$directory" "$session_id"
    elif [[ "$result" == $'__NEW_SESSION__\x1f'* ]]; then
        # Parse: __NEW_SESSION__<US>directory<US>agent_type<US>flags<US>task<US>worktree_name
        local directory agent_type flags task worktree_name
        IFS=$'\x1f' read -r _tag directory agent_type flags task worktree_name <<< "$result"

        # Create new session from form values
        # shellcheck disable=SC2086
        cmd_new_internal "$directory" "$agent_type" "$task" "$worktree_name" $flags
    elif [[ -n "$result" ]]; then
        # Attach to selected session. The session set is unchanged, so the
        # precomputed @am_status_left option (written when sessions were
        # created/killed) is already correct — no sync status-bar call here.
        # client-session-changed fires status-bar in the background to keep
        # state glyphs current.
        tmux_attach "$result"
    fi
}

# Internal: create session from form data (called from fzf_main)
# Usage: cmd_new_internal <directory> [agent_type] [task] [worktree_name] [flags...]
cmd_new_internal() {
    local directory="$1"
    local agent_type="${2:-$(am_default_agent)}"
    local task="${3:-}"
    local worktree_name="${4:-}"
    shift 4 2>/dev/null || shift $#
    local agent_args=("$@")

    local session_name
    session_name=$(agent_launch "$directory" "$agent_type" "$task" "$worktree_name" "${agent_args[@]}")

    if [[ -n "$session_name" ]]; then
        tmux_attach "$session_name"
    fi
}

# Internal: restore a session by launching claude --resume
# Usage: cmd_restore_internal <directory> <session_id>
cmd_restore_internal() {
    local directory="$1"
    local session_id="$2"

    if [[ ! -d "$directory" ]]; then
        log_error "Directory no longer exists: $directory"
        return 1
    fi

    local session_name
    session_name=$(agent_launch "$directory" "claude" "" "" "--resume" "$session_id")

    if [[ -n "$session_name" ]]; then
        tmux_attach "$session_name"
    fi
}

# Command: restore (browse and resume a closed session)
cmd_restore() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        cat <<'EOF'
Usage: am restore

Browse recently closed Claude sessions and resume one.
Shows pane snapshots in the preview panel for visual recall.

Sessions are available as long as their Claude conversation file exists.
EOF
        return 0
    fi

    local result
    if ! result=$(fzf_restore_picker); then
        return 0
    fi

    if [[ "$result" == $'__RESTORE__\x1f'* ]]; then
        local directory session_id
        IFS=$'\x1f' read -r _tag directory session_id <<< "$result"
        cmd_restore_internal "$directory" "$session_id"
    fi
}

read_prompt_input() {
    if [[ $# -gt 0 ]]; then
        printf '%s' "$1"
    elif [[ ! -t 0 ]]; then
        cat
    fi
}

# Command: new
cmd_new() {
    local directory=""
    local dir_given=false
    local agent_type=""
    local task=""
    local worktree_name=""
    local agent_args=()
    local sandbox_share_specs=()
    local yolo_override=""
    local sandbox_override=""
    # shellcheck disable=SC2034
    local worktree_override=""
    local attach_session=true
    local print_session=false
    local initial_prompt=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t|--type)
                agent_type="$2"
                shift 2
                ;;
            -n|--name|--task)
                task="$2"
                shift 2
                ;;
            -d|--dir)
                directory="$2"
                dir_given=true
                shift 2
                ;;
            -w|--worktree)
                shift
                # Next arg is optional name — if it starts with - or is a directory, use default
                if [[ $# -gt 0 && "$1" != -* && ! -d "$1" ]]; then
                    worktree_name="$1"
                    shift
                else
                    worktree_name="__auto__"  # sentinel: generate from session hash
                fi
                ;;
            --yolo|--dangerously-skip-permissions)
                agent_args+=("--yolo")
                yolo_override="true"
                shift
                ;;
            --no-yolo)
                yolo_override="false"
                shift
                ;;
            --sandbox)
                agent_args+=("--sandbox")
                sandbox_override="true"
                shift
                ;;
            --share)
                sandbox_share_specs+=("$2")
                shift 2
                ;;
            --no-sandbox)
                sandbox_override="false"
                shift
                ;;
            --no-worktree)
                # shellcheck disable=SC2034
                worktree_override="false"
                shift
                ;;
            --detach|--no-attach)
                attach_session=false
                shift
                ;;
            --print-session)
                print_session=true
                shift
                ;;
            --)
                shift
                agent_args+=("$@")
                break
                ;;
            -h|--help)
                echo "Usage: am new [options] <directory> [-- extra-args...]"
                echo ""
                echo "If no directory specified, opens interactive picker."
                echo ""
                echo "Options:"
                echo "  -t, --type      Agent type (claude, codex)"
                echo "  -n, --name      Task description"
                echo "  -w, --worktree  Enable git worktree isolation (Claude, Codex)"
                echo "                  Optional: -w <name> for custom worktree name"
                echo "  --sandbox       Run session in Docker sandbox container"
                echo "  --no-sandbox    Disable sandbox even if enabled by default"
                echo "  --share SPEC    Extra sandbox bind mount (<host>[:container][:ro|rw])"
                echo "  --detach        Create the session without attaching"
                echo "  --print-session  Print the created session name"
                echo "  --              Pass remaining args to agent command"
                echo ""
                echo "Examples:"
                echo "  am new                          # Interactive one-page form"
                echo "  am new ~/project                # Specific directory"
                echo "  printf 'Fix bug\n' | am new --detach ~/project"
                echo "  am new ~/project -- --resume    # With agent args"
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                directory="$1"
                dir_given=true
                shift
                ;;
        esac
    done

    # One-page form for fully interactive new-session creation
    if [[ -t 0 && "$dir_given" == false && -z "$agent_type" && -z "$task" && -z "$worktree_name" && ${#agent_args[@]} -eq 0 ]]; then
        _ensure_form
        local form_values flags
        if ! form_values=$(am_new_session_form "$directory" "$(am_default_agent)" "$task" "$worktree_name"); then
            log_info "Cancelled"
            return 0
        fi

        IFS=$'\x1f' read -r directory agent_type task worktree_name flags <<< "$form_values"
        # shellcheck disable=SC2206
        agent_args=($flags)
    else
        if [[ "$dir_given" == false && -t 0 ]]; then
            local picked
            picked=$(fzf_pick_directory)
            if [[ -n "$picked" ]]; then
                directory="$picked"
            else
                log_info "Cancelled"
                return 0
            fi
        elif [[ "$dir_given" == false ]]; then
            directory="."
        fi

        agent_type="${agent_type:-$(am_default_agent)}"

        if [[ "$yolo_override" != "false" ]] && am_maybe_apply_default_yolo "${agent_args[@]}"; then
            agent_args+=("--yolo")
        fi

        if [[ "$sandbox_override" != "false" ]] && am_maybe_apply_default_sandbox "${agent_args[@]}"; then
            agent_args+=("--sandbox")
        fi

        # --yolo implies sandbox + worktree unless explicitly opted out
        if [[ "$yolo_override" == "true" ]]; then
            if [[ "$sandbox_override" != "false" ]] && am_docker_available; then
                # Add --sandbox if not already present
                local _has_sb=false
                for _a in "${agent_args[@]}"; do [[ "$_a" == "--sandbox" ]] && _has_sb=true; done
                if ! $_has_sb; then
                    agent_args+=("--sandbox")
                fi
            fi
            if [[ "$worktree_override" != "false" && -z "$worktree_name" ]]; then
                worktree_name="__auto__"
            fi
        fi
    fi

    initial_prompt=$(read_prompt_input)

    # Launch agent (prompt passed via _AM_LAUNCH_PROMPT to avoid tty buffer overflow
    # when piping long prompts through tmux send-keys)
    _AM_LAUNCH_PROMPT="$initial_prompt"
    # shellcheck disable=SC2034 # read by lib/agents.sh
    AM_SANDBOX_SHARES=("${sandbox_share_specs[@]}")
    local session_name
    session_name=$(agent_launch "$directory" "$agent_type" "$task" "$worktree_name" "${agent_args[@]}")
    # shellcheck disable=SC2034
    AM_SANDBOX_SHARES=()

    if [[ -n "$session_name" ]]; then
        if $print_session || ! $attach_session; then
            echo "$session_name"
        fi
        if $attach_session; then
            tmux_attach "$session_name"
        fi
    fi
}

# Resolve a session name: try exact match, then with prefix
# Usage: resolve_session <name>
# Returns: resolved session name on stdout, or returns 1 if not found
resolve_session() {
    local name="$1"
    if tmux_session_exists "$name"; then
        echo "$name"
    elif tmux_session_exists "${AM_SESSION_PREFIX}${name}"; then
        echo "${AM_SESSION_PREFIX}${name}"
    else
        return 1
    fi
}

resolve_session_fuzzy() {
    local name="$1"

    local resolved
    if resolved=$(resolve_session "$name"); then
        echo "$resolved"
        return 0
    fi

    local matches
    matches=$(tmux_list_am_sessions | grep -i "$name" || true)
    local count
    count=$(printf '%s\n' "$matches" | grep -c .)

    if [[ $count -eq 1 ]]; then
        echo "$matches"
        return 0
    fi

    return 1
}

# Command: attach
cmd_attach() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am attach <session-name>" >&2
        return 1
    fi

    # Exact, prefixed, or single fuzzy match. No sync status-bar refresh —
    # attaching does not change the session set, so precomputed options are
    # still correct.
    local resolved
    if resolved=$(resolve_session_fuzzy "$name"); then
        tmux_attach "$resolved"
        return 0
    fi

    # Zero or multiple fuzzy matches
    local matches
    matches=$(tmux_list_am_sessions | grep -i "$name" || true)
    if [[ -z "$matches" ]]; then
        log_error "No session found matching: $name"
        return 1
    fi

    log_info "Multiple matches found:"
    echo "$matches" >&2
    echo "" >&2
    echo -n "Enter session name: " >&2
    read -r selected
    if [[ -n "$selected" ]]; then
        tmux_attach "$selected"
    fi
}

cmd_send() {
    local do_wait=false
    local timeout_s=600

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --wait)
                do_wait=true
                shift
                ;;
            --timeout)
                timeout_s="${2:-600}"
                shift 2
                ;;
            -h|--help)
                echo "Usage: am send [--wait] [--timeout N] <session-name> [prompt]"
                echo "Read prompt text from argv or stdin and inject it into the running agent pane."
                echo ""
                echo "Options:"
                echo "  --wait       Wait until the agent is ready for input (waiting_input,"
                echo "               waiting_permission, waiting_custom, or idle) before sending"
                echo "  --timeout N  Seconds to wait with --wait before giving up (default: 600)"
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                break
                ;;
        esac
    done

    local name="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am send [--wait] [--timeout N] <session-name> [prompt]"
        return 1
    fi

    local prompt
    prompt=$(read_prompt_input "$*")

    if [[ -z "$prompt" ]]; then
        log_error "Prompt required via argv or stdin"
        echo "Usage: am send [--wait] [--timeout N] <session-name> [prompt]"
        return 1
    fi

    local resolved
    if ! resolved=$(resolve_session_fuzzy "$name"); then
        log_error "Session not found: $name"
        return 1
    fi

    if $do_wait; then
        _ensure_state
        local ready_states="waiting_input,waiting_permission,waiting_custom,idle"
        local reached
        reached=$(agent_wait_state "$resolved" "$ready_states" "$timeout_s")
        local wait_exit=$?
        if [[ $wait_exit -eq 1 ]]; then
            log_error "Session not found while waiting: $resolved"
            return 1
        fi
        if [[ $wait_exit -eq 3 ]]; then
            log_error "Timed out waiting for session to be ready: $resolved"
            return 3
        fi
        if [[ "$reached" == "dead" ]]; then
            log_error "Session exited before prompt could be sent: $resolved"
            return 2
        fi
    fi

    agent_send_prompt "$resolved" "$prompt"
}

peek_capture_output() {
    local session_name="$1"
    local pane_name="$2"
    local lines="${3:-}"
    local pane_target
    pane_target=$(tmux_session_pane_target "$session_name" "$pane_name") || return 1

    local output
    output=$(tmux_capture_pane "$pane_target" "$lines" || true)
    if [[ -n "$output" ]]; then
        output=$(echo "$output" | sed -e :a -e '/^[[:space:]]*$/{' -e '$d' -e N -e ba -e '}')
        if [[ -n "$lines" && "$lines" =~ ^[0-9]+$ ]]; then
            echo "$output" | tail -n "$lines"
        else
            echo "$output"
        fi
    fi
}

peek_follow_logs() {
    local session_name="$1"
    local pane_name="$2"
    local lines="${3:-50}"
    local log_file
    log_file=$(tmux_session_pane_log_file "$session_name" "$pane_name") || return 1

    [[ -f "$log_file" ]] || return 1
    tail -n "$lines" -f "$log_file"
}

peek_follow_poll() {
    local session_name="$1"
    local pane_name="$2"
    local lines="${3:-50}"
    local previous=""
    local current=""

    while tmux_session_exists "$session_name"; do
        current=$(peek_capture_output "$session_name" "$pane_name" "$lines" || true)
        if [[ "$current" != "$previous" ]]; then
            if [[ -n "$previous" && "$current" == "$previous"* ]]; then
                printf '%s' "${current#$previous}"
            else
                [[ -n "$previous" ]] && printf '\n[peek refresh]\n'
                printf '%s\n' "$current"
            fi
            previous="$current"
        fi
        sleep 1
    done
}

peek_history_output() {
    local session_name="$1"
    local pane_name="$2"
    local lines="$3"
    local pattern="$4"

    local log_file
    log_file=$(tmux_session_pane_log_file "$session_name" "$pane_name") || return 1

    if [[ ! -f "$log_file" ]]; then
        log_error "Log not available: $log_file"
        log_error "Enable streaming with: am config set stream_logs true (only affects future sessions)"
        return 1
    fi

    if [[ -n "$pattern" ]]; then
        grep -E -- "$pattern" "$log_file" | tail -n "$lines"
    else
        tail -n "$lines" "$log_file"
    fi
}

cmd_peek() {
    _ensure_state
    local follow=false
    local pane_name="agent"
    local history=false
    local lines=""
    local grep_pattern=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pane)
                pane_name="${2:-}"
                shift 2
                ;;
            --follow|-f)
                follow=true
                shift
                ;;
            --history)
                history=true
                shift
                ;;
            --grep)
                grep_pattern="${2:-}"
                shift 2
                ;;
            --lines)
                lines="${2:-}"
                shift 2
                ;;
            -h|--help)
                echo "Usage: am peek [--pane agent|shell] [--follow|-f] [--lines N] <session-name>"
                echo "Show or follow another session's pane output."
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                break
                ;;
        esac
    done

    if $history; then
        if $follow; then
            log_error "--history is incompatible with --follow"
            return 1
        fi
    elif [[ -n "$grep_pattern" ]]; then
        log_error "--grep requires --history"
        return 1
    fi

    if [[ -z "$lines" ]]; then
        if $history; then
            lines=200
        else
            lines=50
        fi
    fi

    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am peek [--pane agent|shell] [--follow|-f] [--lines N] <session-name>"
        return 1
    fi

    local resolved
    if ! resolved=$(resolve_session_fuzzy "$name"); then
        log_error "Session not found: $name"
        return 1
    fi

    case "$pane_name" in
        agent|top) pane_name="agent" ;;
        shell|bottom) pane_name="shell" ;;
        *)
            log_error "Unknown pane: $pane_name"
            return 1
            ;;
    esac

    if $history; then
        peek_history_output "$resolved" "$pane_name" "$lines" "$grep_pattern"
    elif $follow; then
        if ! peek_follow_logs "$resolved" "$pane_name" "$lines"; then
            peek_follow_poll "$resolved" "$pane_name" "$lines"
        fi
    else
        peek_capture_output "$resolved" "$pane_name" "$lines"
    fi
}

# Command: kill
cmd_kill() {
    if [[ $# -eq 0 ]]; then
        log_error "Session name required (or --all)"
        echo "Usage: am kill <session-name> | --all" >&2
        return 1
    fi

    case "$1" in
        --all|-a)
            local session_count
            session_count=$(tmux_count_am_sessions)
            if [[ $session_count -eq 0 ]]; then
                log_info "No sessions to kill"
                return 0
            fi
            echo -n "Kill ALL agent-manager sessions? [y/N] "
            read -r answer
            if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
                local count
                count=$(agent_kill_all)
                log_success "Killed $count sessions"
            else
                log_info "Aborted"
            fi
            ;;
        *)
            local resolved
            if resolved=$(resolve_session "$1"); then
                agent_kill "$resolved"
            else
                log_error "Session not found: $1"
                return 1
            fi
            ;;
    esac
}

# Command: config
cmd_config() {
    local subcmd="${1:-list}"
    [[ $# -gt 0 ]] && shift

    case "$subcmd" in
        list|show)
            [[ $# -eq 0 ]] || {
                log_error "Usage: am config [list|show]"
                return 1
            }
            am_config_print
            ;;
        get)
            local raw_key="${1:-}"
            if [[ -z "$raw_key" ]]; then
                log_error "Usage: am config get <agent|yolo|logs>"
                return 1
            fi
            local key
            if ! key=$(am_config_key_alias "$raw_key"); then
                log_error "Unknown config key: $raw_key"
                return 1
            fi
            case "$key" in
                default_agent)
                    am_default_agent
                    ;;
                default_yolo)
                    am_default_yolo_enabled && echo true || echo false
                    ;;
                default_sandbox)
                    am_default_sandbox_enabled && echo true || echo false
                    ;;
                stream_logs)
                    am_stream_logs_enabled && echo true || echo false
                    ;;
                sb_network_restrict|sb_allowed_hosts|sandbox.shares)
                    am_config_get "$key"
                    ;;
            esac
            ;;
        set)
            local raw_key="${1:-}"
            local value="${2:-}"
            if [[ -z "$raw_key" || -z "$value" ]]; then
                log_error "Usage: am config set <agent|yolo|logs> <value>"
                return 1
            fi
            local key key_type
            if ! key=$(am_config_key_alias "$raw_key"); then
                log_error "Unknown config key: $raw_key"
                return 1
            fi
            key_type=$(am_config_key_type "$key")
            if ! am_config_value_is_valid "$key" "${value,,}"; then
                log_error "Invalid value for $raw_key: $value"
                return 1
            fi
            am_config_set "$key" "${value,,}" "$key_type"
            am_config_print
            ;;
        unset|rm)
            local raw_key="${1:-}"
            if [[ -z "$raw_key" ]]; then
                log_error "Usage: am config unset <agent|yolo|logs>"
                return 1
            fi
            local key
            if ! key=$(am_config_key_alias "$raw_key"); then
                log_error "Unknown config key: $raw_key"
                return 1
            fi
            am_config_unset "$key"
            am_config_print
            ;;
        help|-h|--help)
            cat <<'EOF'
Usage:
  am config                 Show effective defaults
  am config get <key>       Get one value
  am config set <key> <v>   Save a default
  am config unset <key>     Remove a saved value

Keys:
  agent    Default agent type
  yolo     Default yolo mode (true/false)
  sandbox  Default sandbox mode (true/false)
  logs            Default pane log streaming (true/false)
  sandbox-shares  Sticky sandbox bind mounts (<host>[:container][:ro|rw], comma-separated)

Precedence:
  CLI flag > environment variable > saved config > built-in default
EOF
            ;;
        *)
            log_error "Unknown config subcommand: $subcmd"
            return 1
            ;;
    esac
}

# Command: info
cmd_info() {
    _ensure_state
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am info <session-name>"
        return 1
    fi

    local resolved
    if ! resolved=$(resolve_session "$name"); then
        log_error "Session not found: $name"
        return 1
    fi

    agent_info "$resolved"
}

# Command: status
cmd_status() {
    _ensure_state
    local json=false
    local session_arg=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json|-j)
                json=true
                shift
                ;;
            -h|--help)
                echo "Usage: am status [--json] [<session-name>]"
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                session_arg="$1"
                shift
                ;;
        esac
    done

    # Single-session mode
    if [[ -n "$session_arg" ]]; then
        local resolved
        if ! resolved=$(resolve_session_fuzzy "$session_arg"); then
            log_error "Session not found: $session_arg"
            return 1
        fi

        local state
        state=$(agent_get_state "$resolved")

        if $json; then
            local fields directory branch agent_type task
            fields=$(registry_get_fields "$resolved" directory branch agent_type task)
            IFS='|' read -r directory branch agent_type task <<< "$fields"
            local activity created
            activity=$(tmux_get_activity "$resolved")
            created=$(tmux_get_created "$resolved")
            jq -n \
                --arg name "$resolved" \
                --arg state "$state" \
                --arg dir "$directory" \
                --arg branch "$branch" \
                --arg agent "$agent_type" \
                --arg task "$task" \
                --arg activity "${activity:-0}" \
                --arg created "${created:-0}" \
                '{name: $name, state: $state, directory: $dir, branch: $branch,
                  agent_type: $agent, task: $task,
                  activity: ($activity | tonumber), created: ($created | tonumber)}'
        else
            agent_info "$resolved"
            printf 'State: %s\n' "$state"
        fi

        [[ "$state" == "dead" ]] && return 2
        return 0
    fi

    # All-sessions mode
    if $json; then
        fzf_list_json
        return 0
    fi

    registry_gc >/dev/null 2>&1
    # Refresh task fields from pane titles / Claude JSONL. Throttled to once
    # per 60s via shared marker, so the cost is bounded across rapid invocations.
    auto_title_scan >/dev/null 2>&1

    local count
    count=$(tmux_count_am_sessions)

    printf '%b\n' "${BOLD}Agent Manager Status${RESET}"
    echo "===================="
    echo
    echo "Active sessions: $count"
    echo

    if [[ $count -gt 0 ]]; then
        printf '%b\n' "${BOLD}Sessions:${RESET}"
        fzf_list_simple
    else
        echo "Run 'am new' to create your first session."
    fi
}

# Command: wait
cmd_wait() {
    _ensure_state
    local target_states="waiting_input,waiting_permission,waiting_custom,idle,dead"
    local timeout_s=600
    local json=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --state)
                target_states="${2:-}"
                shift 2
                ;;
            --timeout)
                timeout_s="${2:-600}"
                shift 2
                ;;
            --json)
                json=true
                shift
                ;;
            -h|--help)
                echo "Usage: am wait [--state <states>] [--timeout N] [--json] <session-name>"
                echo "  states: comma-separated list of: starting,running,waiting_input,"
                echo "          waiting_permission,waiting_custom,waiting_background,idle,"
                echo "          unknown,dead"
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                break
                ;;
        esac
    done

    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am wait [--state <states>] [--timeout N] <session-name>"
        return 1
    fi

    local resolved
    if ! resolved=$(resolve_session_fuzzy "$name"); then
        log_error "Session not found: $name"
        return 1
    fi

    local reached exit_code=0
    reached=$(agent_wait_state "$resolved" "$target_states" "$timeout_s") || exit_code=$?

    if $json; then
        jq -n --arg session "$resolved" --arg state "$reached" \
            '{session: $session, state: $state}'
    else
        echo "$reached"
    fi

    return $exit_code
}

# Command: interrupt
cmd_interrupt() {
    _ensure_state
    local confirmed=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --confirm)
                confirmed=true
                shift
                ;;
            -h|--help)
                echo "Usage: am interrupt [--confirm] <session-name>"
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                return 1
                ;;
            *)
                break
                ;;
        esac
    done

    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Session name required"
        echo "Usage: am interrupt <session-name>"
        return 1
    fi

    local resolved
    if ! resolved=$(resolve_session_fuzzy "$name"); then
        log_error "Session not found: $name"
        return 1
    fi

    local state
    state=$(agent_get_state "$resolved")
    case "$state" in
        idle|dead)
            log_warn "Session is already $state; nothing to interrupt"
            return 1
            ;;
    esac

    if $confirmed; then
        printf 'Interrupt session %s (state: %s)? [y/N] ' "$resolved" "$state" >&2
        local answer
        read -r answer
        [[ "$answer" == "y" || "$answer" == "Y" ]] || { log_info "Aborted"; return 0; }
    fi

    local pane_target
    pane_target=$(tmux_session_pane_target "$resolved" "agent")
    tmux_send_keys "$pane_target" "C-c"
    log_info "Sent interrupt to $resolved"
}

# Command: sandbox
cmd_sandbox() {
    _ensure_sandbox
    local action="${1:-}"
    shift || true

    case "$action" in
        ps)
            sb_ps
            ;;
        prune)
            sb_prune
            ;;
        build)
            local no_cache=0
            [[ "${1:-}" == "--no-cache" ]] && no_cache=1
            sb_build "$no_cache"
            ;;
        reset)
            local confirm=0
            [[ "${1:-}" == "--confirm" ]] && confirm=1
            sb_reset "$confirm"
            ;;
        status)
            local session="${1:-}"
            [[ -z "$session" ]] && { log_error "Usage: am sb status <session>"; return 1; }
            sandbox_status "$session"
            ;;
        enter)
            local session="${1:-}"
            [[ -z "$session" ]] && { log_error "Usage: am sb enter <session>"; return 1; }
            sandbox_enter "$session"
            ;;
        ""|help|--help|-h)
            cat <<'EOF'
Usage: am sb <subcommand>

Subcommands:
  ps
  prune
  build [--no-cache]
  reset --confirm
  enter <session>
  status <session>
EOF
            ;;
        map|unmap|maps|sync|edit|shell)
            log_error "Removed subcommand: $action (sandbox now uses a bind-mounted home directory)"
            return 1
            ;;
        list|ls|rebuild|identity)
            log_error "Legacy sandbox subcommand removed: $action"
            return 1
            ;;
        *)
            log_error "Unknown sandbox subcommand: $action"
            return 1
            ;;
    esac
}

# Helper: compare version strings (true if actual >= required)
_install_version_ge() {
    local required="$1"
    local actual="$2"
    local oldest
    oldest=$(printf '%s\n%s' "$required" "$actual" | sort -V | head -1)
    [[ "$oldest" == "$required" ]]
}

# Helper: check a single dependency, optionally with minimum version
_install_check_cmd() {
    local cmd="$1"
    local min_version="${2:-}"

    if ! command -v "$cmd" &>/dev/null; then
        log_warn "  $cmd ... MISSING"
        return 1
    fi

    if [[ -z "$min_version" ]]; then
        log_success "  $cmd ... OK"
        return 0
    fi

    local actual_version=""
    case "$cmd" in
        tmux) actual_version=$(tmux -V 2>/dev/null | sed -E 's/tmux ([0-9.]+).*/\1/') ;;
        fzf)  actual_version=$(fzf --version 2>/dev/null | sed -E 's/([0-9.]+).*/\1/') ;;
    esac

    if [[ -z "$actual_version" ]]; then
        log_warn "  $cmd ... version unknown (need >= $min_version)"
        return 1
    fi

    if _install_version_ge "$min_version" "$actual_version"; then
        log_success "  $cmd $actual_version ... OK (>= $min_version)"
        return 0
    else
        log_warn "  $cmd $actual_version ... too old (need >= $min_version)"
        return 1
    fi
}

_install_go_version() {
    go version 2>/dev/null | sed -E 's/^go version go([0-9]+(\.[0-9]+){1,2}).*/\1/'
}

_install_go_ready_for_build() {
    local min_version="$1"
    local actual_version

    if ! command -v go &>/dev/null; then
        log_warn "  Go not found -- run 'make build' after installing Go >= $min_version"
        return 1
    fi

    actual_version=$(_install_go_version)
    if [[ -z "$actual_version" ]]; then
        log_warn "  Go version unknown (need >= $min_version); skipping Go helper build"
        return 1
    fi

    if _install_version_ge "$min_version" "$actual_version"; then
        log_success "  Go $actual_version ... OK (>= $min_version)"
        return 0
    fi

    log_warn "  Go $actual_version ... too old for compiled helpers (need >= $min_version); skipping Go helper build"
    return 1
}

# Command: install
cmd_install() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        cat <<'EOF'
Usage: am install [options]

First-time setup: check dependencies, create config, symlink skills,
and install am onto PATH.

Options (forwarded to scripts/install.sh):
  --prefix <dir>      Install directory (default: ~/.local/bin)
  --shell-rc <file>   Shell rc file to update
  --tmux-conf <file>  tmux config to clean up
  --no-shell          Skip shell rc update
  --no-tmux           Skip tmux config cleanup
  -y, --yes           Non-interactive mode
  -h, --help          Show this help
EOF
        return 0
    fi

    echo -e "${BOLD}am install — first-time setup${RESET}" >&2
    echo "" >&2

    local warnings=0
    local steps_done=()

    # --- Step 1: Check dependencies ---
    echo -e "${BOLD}Checking dependencies...${RESET}" >&2
    _install_check_cmd tmux 3.0  || (( warnings += 1 ))
    _install_check_cmd fzf 0.40  || (( warnings += 1 ))
    _install_check_cmd jq        || (( warnings += 1 ))
    _install_check_cmd git       || (( warnings += 1 ))
    steps_done+=("Dependencies checked")

    # --- Step 2: Create config ---
    echo "" >&2
    echo -e "${BOLD}Setting up config...${RESET}" >&2
    # am_init + am_config_init already called by main() before we get here
    log_success "  Config directory: $AM_DIR"
    log_success "  Config file: $AM_CONFIG"
    steps_done+=("Config: $AM_CONFIG")

    # --- Step 3: Symlink skills for Claude Code discovery ---
    echo "" >&2
    echo -e "${BOLD}Setting up skills...${RESET}" >&2
    local skills_root="$AM_SCRIPT_DIR/skills"
    local skills_dir="${AM_CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"

    if [[ ! -d "$skills_root" ]]; then
        log_warn "  Skills source root not found: $skills_root"
        (( warnings += 1 ))
    else
        mkdir -p "$skills_dir"
        shopt -s nullglob
        local skill_src skill_name skill_target existing
        for skill_src in "$skills_root"/*/; do
            skill_src="${skill_src%/}"
            [[ -f "$skill_src/SKILL.md" ]] || continue
            skill_name=$(basename "$skill_src")
            skill_target="$skills_dir/$skill_name"

            if [[ -L "$skill_target" ]]; then
                existing=$(readlink "$skill_target")
                # Compare resolved real paths, not raw link text: an existing
                # link may be relative (or stale) yet still point at skill_src.
                local existing_real
                existing_real=$(cd "$(dirname "$skill_target")" 2>/dev/null && cd "$existing" 2>/dev/null && pwd -P)
                if [[ "$existing_real" == "$skill_src" ]]; then
                    log_success "  Symlink already exists: $skill_target"
                    steps_done+=("Skill $skill_name: verified")
                else
                    # Re-point to the known-correct absolute path.
                    ln -sfn "$skill_src" "$skill_target"
                    log_success "  Re-pointed: $skill_target -> $skill_src"
                    steps_done+=("Skill $skill_name: re-pointed")
                fi
            elif [[ -e "$skill_target" ]]; then
                log_warn "  Target exists but is not a symlink: $skill_target"
                (( warnings += 1 ))
            else
                ln -s "$skill_src" "$skill_target"
                log_success "  Symlinked: $skill_target -> $skill_src"
                steps_done+=("Skill $skill_name: symlinked")
            fi
        done
        shopt -u nullglob
    fi

    # --- Step 4: Install am onto PATH (via scripts/install.sh) ---
    echo "" >&2
    echo -e "${BOLD}Installing am onto PATH...${RESET}" >&2
    "$AM_SCRIPT_DIR/scripts/install.sh" "$@"
    steps_done+=("PATH setup complete")

    # --- Step 5: Build compiled helpers ---
    echo "" >&2
    echo -e "${BOLD}Building compiled helpers...${RESET}" >&2
    local min_go_version="1.19"
    if _install_go_ready_for_build "$min_go_version"; then
        local go_ok=true
        if ( cd "$AM_SCRIPT_DIR" && go build -o bin/am-list-internal ./cmd/am-list-internal/ ) 2>&1; then
            log_success "  Built bin/am-list-internal"
        else
            log_warn "  go build failed for am-list-internal"
            go_ok=false
        fi
        if ( cd "$AM_SCRIPT_DIR" && go build -o bin/am-browse ./cmd/am-browse/ ) 2>&1; then
            log_success "  Built bin/am-browse"
        else
            log_warn "  go build failed for am-browse"
            go_ok=false
        fi
        if $go_ok; then
            steps_done+=("Go binaries built")
        else
            (( warnings += 1 ))
        fi
    else
        (( warnings += 1 ))
    fi

    # --- Step 6: Refresh dedicated tmux config ---
    echo "" >&2
    echo -e "${BOLD}Refreshing tmux config...${RESET}" >&2
    source "$AM_SCRIPT_DIR/lib/tmux.sh"
    am_tmux_config_path >/dev/null
    log_success "  Refreshed dedicated tmux config: $AM_TMUX_CONF"
    steps_done+=("tmux config refreshed")

    # --- Summary ---
    echo "" >&2
    echo -e "${BOLD}Summary${RESET}" >&2
    local step
    for step in "${steps_done[@]}"; do
        echo "  * $step" >&2
    done
    if [[ $warnings -gt 0 ]]; then
        log_warn "$warnings warning(s) -- review above"
    fi
    echo "" >&2
    log_success "Setup complete! Run 'am version' to verify."
}

# Main entry point
main() {
    # Initialize tracing if requested
    trace_init

    # Initialize
    am_init
    am_config_init

    # Parse command
    local cmd="${1:-browse}"
    [[ $# -gt 0 ]] && shift

    # Install runs before strict dependency checks (it verifies deps itself)
    if [[ "$cmd" == "install" ]]; then
        cmd_install "$@"
        return $?
    fi

    # Check dependencies
    require_cmd tmux
    require_cmd fzf
    require_cmd jq

    case "$cmd" in
        browse)
            cmd_browse
            ;;
        list|ls)
            cmd_list "$@"
            ;;
        new|create|n)
            cmd_new "$@"
            ;;
        send)
            cmd_send "$@"
            ;;
        peek)
            cmd_peek "$@"
            ;;
        attach|a)
            cmd_attach "$@"
            ;;
        kill|rm|k)
            cmd_kill "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        info|i)
            cmd_info "$@"
            ;;
        status|s)
            cmd_status "$@"
            ;;
        wait)
            cmd_wait "$@"
            ;;
        interrupt)
            cmd_interrupt "$@"
            ;;
        restore)
            cmd_restore "$@"
            ;;
        sandbox|sb)
            cmd_sandbox "$@"
            ;;
        *)
            # If it looks like a path, treat as "new <path>"
            if [[ -d "$cmd" ]]; then
                cmd_new "$cmd" "$@"
            else
                log_error "Unknown command: $cmd"
                echo "Run 'am help' for usage"
                exit 1
            fi
            ;;
    esac
}

main "$@"
