#!/usr/bin/env bash
# Kill a session and switch the invoking client to the last used one if we killed
# the current session.

client_name=""
target=""

if [[ $# -ge 2 ]]; then
    client_name="${1:-}"
    target="${2:-}"
elif [[ $# -eq 1 ]]; then
    target="${1:-}"
fi

if [[ -z "$target" ]]; then
    exit 1
fi

# Resolve the real script path so installed symlinks still find the repo libs.
script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd -P)"
    script_path="$(readlink "$script_path")"
    [[ "$script_path" != /* ]] && script_path="$script_dir/$script_path"
done
script_dir="$(cd "$(dirname "$script_path")" && pwd -P)"
repo_dir="$(cd "$script_dir/.." && pwd -P)"

# Source helpers before using am_tmux/agent_kill.
source "$repo_dir/lib/utils.sh"
source "$repo_dir/lib/tmux.sh"
source "$repo_dir/lib/registry.sh"
source "$repo_dir/lib/agents.sh"

# Old bindings may still call this helper with only the target session. Fall back
# to tmux's implicit current client in that case so running servers keep working
# until they reload the updated binding.
if [[ -z "$client_name" ]]; then
    client_name=$(am_tmux display-message -p '#{client_name}' 2>/dev/null || true)
fi

# Get current attached session
if [[ -n "$client_name" ]]; then
    current=$(am_tmux display-message -c "$client_name" -p '#{session_name}' 2>/dev/null || true)
else
    current=$(am_tmux display-message -p '#{session_name}' 2>/dev/null || true)
fi

# If killing the current session, switch to another one first
if [[ "$target" == "$current" ]]; then
    # Find the next best session (most recent that isn't the target)
    next=$(am_tmux list-sessions -F '#{session_activity} #{session_name}' 2>/dev/null \
        | grep ' am-' \
        | grep -v " ${target}$" \
        | sort -rn \
        | head -1 \
        | cut -d' ' -f2 || true)

    if [[ -n "$next" ]]; then
        if [[ -n "$client_name" ]]; then
            am_tmux switch-client -c "$client_name" -t "$next"
        else
            am_tmux switch-client -t "$next"
        fi
    fi
fi

# Now kill the target session
agent_kill "$target"
