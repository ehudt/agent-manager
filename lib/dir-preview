#!/usr/bin/env bash
# dir-preview - Standalone preview for directory picker fzf panel
# Usage: dir-preview <line>
# Where <line> may be "path<TAB>annotation"

set -euo pipefail

line="${1:-}"
[[ -z "$line" ]] && exit 0

# Strip annotation (tab-separated)
d=$(echo "$line" | cut -f1)
d="${d/#\~/$HOME}"

if [[ ! -d "$d" ]]; then
    echo "Type a path or select from list"
    exit 0
fi

echo "── Git ──"
if git -C "$d" rev-parse --git-dir >/dev/null 2>&1; then
    branch=$(git -C "$d" branch --show-current 2>/dev/null || true)
    if [[ -n "$branch" ]]; then
        echo "Branch: $branch"
    else
        echo "Detached HEAD"
    fi
else
    echo "(not a git repo)"
fi

echo ""
echo "── Files ──"
command ls -la "$d" 2>/dev/null | head -15
