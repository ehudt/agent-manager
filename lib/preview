#!/usr/bin/env bash
# preview - Fast standalone preview for fzf
# Usage: preview <session_name>

set -euo pipefail

session_name="${1:-}"

if [[ -z "$session_name" ]]; then
    echo "No session selected"
    exit 0
fi

# Minimal init — only source utils and tmux (skip registry; use jq directly)
source "$(dirname "${BASH_SOURCE[0]}")/utils.sh"
source "$(dirname "${BASH_SOURCE[0]}")/tmux.sh"

# Check session exists
if ! am_tmux has-session -t "$session_name" 2>/dev/null; then
    echo "Session not found: $session_name"
    exit 0
fi

# Read directory and task from registry in one jq call (avoids sourcing registry.sh)
AM_REGISTRY="${AM_REGISTRY:-${HOME}/.agent-manager/sessions.json}"
directory="" task=""
if [[ -f "$AM_REGISTRY" ]]; then
    local_fields=$(jq -r --arg name "$session_name" \
        '.sessions[$name] | [.directory // "", .task // ""] | join("|")' \
        "$AM_REGISTRY" 2>/dev/null || true)
    IFS='|' read -r directory task <<< "$local_fields"
fi

echo -e "\033[1mSession:\033[0m $session_name"
if [[ -n "$directory" ]]; then
    echo -e "\033[1mDirectory:\033[0m $directory"
fi
if [[ -n "$task" ]]; then
    echo ""
    echo -e "\033[1;36m$task\033[0m"
fi

# Show first user message from Claude JSONL if available
if [[ -n "$directory" ]]; then
    first_msg=$(claude_first_user_message "$directory" 2>/dev/null || true)
    if [[ -n "$first_msg" ]]; then
        echo ""
        echo -e "\033[2m$first_msg\033[0m"
    fi
fi
echo ""

# Capture terminal output from the agent pane (top pane)
output=$(tmux_capture_pane "$session_name:.{top}" 50 || tmux_capture_pane "$session_name" 50)

if [[ -n "$output" ]]; then
    # Strip trailing blank lines (capture-pane pads with empties)
    echo "$output" | sed -e :a -e '/^[[:space:]]*$/{' -e '$d' -e N -e ba -e '}'
else
    echo "(Unable to capture)"
fi
