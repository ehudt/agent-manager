#!/usr/bin/env bash
# status-bar - tmux status renderer for the agent-manager dedicated server.
#
# Renders all am sessions as a clickable tab strip. Whole bottom bar acts as
# a tab switcher: each tab carries index, state glyph, dir/branch, task, age.
# Clicking a tab in status-left switches to that session via MouseDown1Status.
#
# Outputs:
# - stdout: clickable tab strip wrapped in #[range=user|<sid>]…#[norange],
#   consumed by status-left.
# - @am_sidebar tmux option: compact tab strip (no tasks/ages, no range
#   wrappers) consumed by pane-border-format.
# - @am_attention tmux option: attention counter for non-current sessions,
#   consumed by status-right.
#
# Called by tmux as: #(/path/to/status-bar #{session_name})

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/utils.sh"
source "$SCRIPT_DIR/tmux.sh"
source "$SCRIPT_DIR/registry.sh"
source "$SCRIPT_DIR/state.sh"

# Modes: --print emits clickable strip on stdout (used by tests and ad-hoc
# inspection). Default mode runs only for side effects: writes per-session
# @am_status_left, @am_sidebar, and @am_attention options. Keeping stdout
# empty in default mode lets tmux invoke the script for periodic refresh
# (via a #() in status-right) without polluting the rendered bar.
print_mode=false
if [[ "${1:-}" == "--print" ]]; then
    print_mode=true
    shift
fi

current="${1:-}"
AM_STATE_DIR="${AM_STATE_DIR:-/tmp/am-state}"

# Truncation budgets (chars; treats each glyph as 1 col).
NON_CURRENT_LABEL_MAX=20
NON_CURRENT_TASK_MAX=18
CURRENT_LABEL_MAX=28
CURRENT_TASK_MAX=42

# State lookup tables — avoid spawning a subshell per session for the glyph
# and color helpers. Status-bar runs on the hot path between Enter and attach;
# eliminating these $()  forks is the difference between "instant" and "lag".
declare -A GLYPH=(
    [running]='▸'
    [waiting_input]='●'
    [waiting_permission]='⚠'
    [waiting_custom]='◆'
    [starting]='◌'
    [dead]='✕'
)
declare -A COLOR=(
    [running]='colour75'
    [waiting_input]='colour114'
    [waiting_permission]='colour214'
    [waiting_custom]='colour213'
    [starting]='colour221'
    [dead]='colour196'
)

# Truncate to `_T` (no $() fork). Caller reads `$_T`.
_trunc() {
    local s="$1" max="$2"
    if (( ${#s} > max )); then
        _T="${s:0:$((max - 3))}..."
    else
        _T="$s"
    fi
}

# Compact age to `_A` (no $() fork). Caller reads `$_A`.
_compact_age_set() {
    local s="$1"
    (( s < 0 )) && s=0
    if   (( s < 60 ));    then _A="${s}s"
    elif (( s < 3600 ));  then _A="$((s/60))m"
    elif (( s < 86400 )); then _A="$((s/3600))h"
    else                       _A="$((s/86400))d"
    fi
}

# Inline hook-state read — _state_from_hook in state.sh forks `stat` and
# `head`; status-bar runs on the hot path so we drop the `head` fork by
# reading the first line via bash builtin. Writes to `_HS`.
_hook_state_set() {
    local session="$1"
    local state_file="$AM_STATE_DIR/$session"
    _HS=""
    [[ -f "$state_file" ]] || return 0
    local mtime
    mtime=$(stat -c %Y "$state_file" 2>/dev/null || stat -f %m "$state_file" 2>/dev/null) || return 0
    (( now - mtime > 180 )) && return 0
    local line=""
    IFS= read -r line < "$state_file" 2>/dev/null || true
    case "$line" in
        running|waiting_input|waiting_permission|waiting_custom) _HS="$line" ;;
    esac
}

# Bulk-data variant of _state_pane_is_shell. Reads from SESSION_TOP_PID and
# PROC_COMM / PROC_CHILDREN tables built once per status-bar run, instead of
# forking tmux+ps repeatedly.
_pane_is_shell_bulk() {
    local pid="${SESSION_TOP_PID[$1]:-}"
    [[ -z "$pid" ]] && return 1
    local comm="${PROC_COMM[$pid]:-}"
    case "$comm" in
        bash|zsh|sh|fish|dash|-bash|-zsh|-sh|-fish|-dash) ;;
        *) return 1 ;;
    esac
    local cpid ccomm
    for cpid in ${PROC_CHILDREN[$pid]:-}; do
        ccomm="${PROC_COMM[$cpid]:-}"
        case "$ccomm" in
            bash|zsh|sh|fish|dash|-bash|-zsh|-sh|-fish|-dash|"") ;;
            *) return 1 ;;
        esac
    done
    return 0
}

# Status-bar state detection — fork-free for the common case. Order:
#   1. Hook state file (Claude's primary signal)
#   2. Bulk shell check → idle (status bar treats dead as idle visually;
#      the periodic full refresh in lib/state.sh can upgrade to dead later
#      via agent_classify_exit, but that path is too fork-heavy to run on
#      every attach)
#   3. JSONL fallback for Claude
#   4. Pane-content patterns (still forks; only reached for live agents
#      without a hook signal)
_fast_state() {
    local session="$1" agent_type="$2" dir="$3"
    _hook_state_set "$session"
    # Hook short-circuit: only for terminal waiting states. `running` falls
    # through to pane so permission prompts painted during a tool call are
    # caught (otherwise status-bar shows ▸ while browser shows ⚠).
    case "$_HS" in
        waiting_input|waiting_permission|waiting_custom)
            echo "$_HS"
            return
            ;;
    esac
    if _pane_is_shell_bulk "$session"; then
        echo "idle"
        return
    fi
    if [[ "$agent_type" == "claude" && -n "$dir" ]]; then
        local jstate
        jstate=$(_state_from_jsonl "$dir" 2>/dev/null || true)
        if [[ -n "$jstate" ]]; then
            echo "$jstate"
            return
        fi
    fi
    _state_from_pane "$session" "$agent_type" --skip-alive-check 2>/dev/null || echo "${_HS:-running}"
}

# Single tmux call returns ordering + activity timestamps. Sort by creation
# time ascending so newly created sessions always appear at the end (stable
# numbering for prefix+1..9 keybindings).
mapfile -t session_meta < <(am_tmux list-sessions -F '#{session_created} #{session_activity} #{session_name}' 2>/dev/null \
    | grep " ${AM_SESSION_PREFIX}" \
    | sort -k1,1n -k3,3 || true)

[[ ${#session_meta[@]} -eq 0 ]] && exit 0

# Refresh registry task field from pane titles / Claude JSONL fallback before
# the bulk read below. Self-throttled to 60s via $AM_DIR/.title_scan_last, so
# the 5s status-interval tick stays cheap. Without this, brand-new sessions
# (and post-/clear conversations) stay untitled in the status bar until the
# user runs `am`.
auto_title_scan >/dev/null 2>&1 || true

# Bulk registry read — one jq invocation for all sessions' fields, indexed by
# name into associative arrays. Replaces N separate `registry_get_fields`
# calls (each forking jq) with a single fork.
declare -A REG_DIR=() REG_BRANCH=() REG_AGENT=() REG_TASK=()
if [[ -r "${AM_REGISTRY:-}" ]]; then
    while IFS=$'\x1f' read -r _reg_name _reg_dir _reg_branch _reg_agent _reg_task; do
        [[ -n "$_reg_name" ]] || continue
        REG_DIR[$_reg_name]=$_reg_dir
        REG_BRANCH[$_reg_name]=$_reg_branch
        REG_AGENT[$_reg_name]=$_reg_agent
        REG_TASK[$_reg_name]=$_reg_task
    done < <(jq -r --arg us $'\x1f' '
        .sessions | to_entries[] |
        [.key, (.value.directory // ""), (.value.branch // ""),
         (.value.agent_type // ""), (.value.task // "")] | join($us)
    ' "$AM_REGISTRY" 2>/dev/null || true)
fi

now=$(date +%s)

# Bulk pane-pid fetch: one tmux list-panes call indexes the top pane for each
# session. Replaces N `display-message #{pane_pid}` forks inside the loop.
declare -A SESSION_TOP_PID=()
while IFS='|' read -r _bp_sess _bp_top _bp_pid; do
    [[ "$_bp_top" == "1" ]] || continue
    [[ "$_bp_sess" == "${AM_SESSION_PREFIX}"* ]] || continue
    SESSION_TOP_PID[$_bp_sess]=$_bp_pid
done < <(am_tmux list-panes -a -F '#{session_name}|#{pane_at_top}|#{pane_pid}' 2>/dev/null || true)

# Bulk process-table fetch: one ps -eo call yields comm + children for every
# pid. Replaces ~3 ps forks per session in _state_pane_is_shell.
declare -A PROC_COMM=() PROC_CHILDREN=()
while read -r _bp_p _bp_pp _bp_c; do
    [[ -z "$_bp_p" || "$_bp_p" == "PID" ]] && continue
    PROC_COMM[$_bp_p]=$_bp_c
    PROC_CHILDREN[$_bp_pp]="${PROC_CHILDREN[$_bp_pp]:-} $_bp_p"
done < <(ps -eo pid=,ppid=,comm= 2>/dev/null || true)

# Pass 1: collect per-session data once. We then format N strip variants
# (one per "perspective session") using this cached data, so each session's
# @am_status_left option holds a strip with itself marked as current. tmux
# then reads the precomputed option on session switch — instant feedback,
# no async #() job to wait on.
declare -a S_NAME S_LABEL S_STATE S_GLYPH S_COLOR S_TASK S_AGE
declare -A STATE_TOTAL=()

for i in "${!session_meta[@]}"; do
    # Bash-only parse of "<created> <activity> <name>" — no awk fork.
    read -r _created activity session <<< "${session_meta[$i]}"

    dir="${REG_DIR[$session]:-}"
    branch="${REG_BRANCH[$session]:-}"
    agent_type="${REG_AGENT[$session]:-}"
    task="${REG_TASK[$session]:-}"

    # Inline _label: basename via parameter expansion, no basename fork.
    if [[ -n "$dir" ]]; then
        label="${dir##*/}"
        [[ -n "$branch" ]] && label+="/$branch"
    else
        label="${session#"${AM_SESSION_PREFIX}"}"
    fi

    state=$(_fast_state "$session" "$agent_type" "$dir")
    [[ -z "$state" ]] && state="idle"

    age=""
    if [[ -n "$activity" && "$activity" =~ ^[0-9]+$ ]]; then
        _compact_age_set $(( now - activity ))
        age="$_A"
    fi

    S_NAME[i]=$session
    S_LABEL[i]=$label
    S_STATE[i]=$state
    S_GLYPH[i]="${GLYPH[$state]:-○}"
    S_COLOR[i]="${COLOR[$state]:-colour240}"
    S_TASK[i]=${task:-∅}
    S_AGE[i]=$age

    case "$state" in
        waiting_input|waiting_permission|waiting_custom|running)
            STATE_TOTAL[$state]=$(( ${STATE_TOTAL[$state]:-0} + 1 ))
            ;;
    esac
done

# Build a strip from perspective P (P_idx is the "current" tab index).
# Writes to `_STRIP` (no $() fork on caller side).
_build_strip() {
    local p_idx="$1" want_clickable="$2" want_compact="$3"
    local strip="" first=true
    local i idx state color glyph label task age label_t task_t age_part
    local body cur_fg entry
    for i in "${!S_NAME[@]}"; do
        idx=$((i + 1))
        state="${S_STATE[$i]}"
        color="${S_COLOR[$i]}"
        glyph="${S_GLYPH[$i]}"
        label="${S_LABEL[$i]}"
        task="${S_TASK[$i]}"
        age="${S_AGE[$i]}"

        if (( i == p_idx )); then
            _trunc "$label" "$CURRENT_LABEL_MAX"; label_t="$_T"
            _trunc "$task" "$CURRENT_TASK_MAX"; task_t="$_T"
        else
            _trunc "$label" "$NON_CURRENT_LABEL_MAX"; label_t="$_T"
            _trunc "$task" "$NON_CURRENT_TASK_MAX"; task_t="$_T"
        fi

        age_part=""
        [[ -n "$age" ]] && age_part=" (${age})"

        if [[ "$want_compact" == "true" ]]; then
            body="${idx}|${glyph} ${label_t}"
        else
            body="${idx}|${glyph} ${label_t} · ${task_t}${age_part}"
        fi

        cur_fg='colour16'
        case "$state" in
            idle|dead|starting) cur_fg='colour231' ;;
        esac

        if (( i == p_idx )); then
            entry="#[fg=${cur_fg},bg=${color},bold] ${body} #[default]"
        else
            entry="#[fg=${color},bg=colour234] ${body} #[default]"
        fi

        if ! $first; then
            strip+="  "
        fi
        first=false

        if [[ "$want_clickable" == "true" ]]; then
            strip+="#[range=user|${S_NAME[$i]}]${entry}#[norange]"
        else
            strip+="$entry"
        fi
    done
    _STRIP="$strip"
}

# Build attention counter from perspective P (exclude P's own state).
# Writes to `_ATT`.
_build_attention() {
    local p_idx="$1"
    local p_state="${S_STATE[$p_idx]}"
    local att="" st cnt g c
    for st in waiting_permission waiting_custom waiting_input; do
        cnt=${STATE_TOTAL[$st]:-0}
        [[ "$p_state" == "$st" ]] && cnt=$(( cnt - 1 ))
        (( cnt <= 0 )) && continue
        g="${GLYPH[$st]}"
        c="${COLOR[$st]}"
        [[ -n "$att" ]] && att+=" "
        att+="#[fg=${c},bold]${cnt}${g}#[default]"
    done
    _ATT="$att"
}

# Write per-session options. Each session sees itself as current — switch is
# instant because tmux reads the precomputed option. All set-option calls
# are chained into a single tmux invocation (tmux's `;` command separator)
# so we pay one fork+exec instead of 3N.
batch_args=()
for p_idx in "${!S_NAME[@]}"; do
    p_session="${S_NAME[$p_idx]}"
    _build_strip "$p_idx" true false;  status_left="$_STRIP"
    _build_strip "$p_idx" false true;  sidebar="$_STRIP"
    _build_attention "$p_idx";         attention="$_ATT"

    (( ${#batch_args[@]} > 0 )) && batch_args+=(';')
    batch_args+=(set-option -q -t "$p_session" @am_status_left "$status_left")
    batch_args+=(';')
    batch_args+=(set-option -q -t "$p_session" @am_sidebar "$sidebar")
    batch_args+=(';')
    batch_args+=(set-option -q -t "$p_session" @am_attention "$attention")
done

if (( ${#batch_args[@]} > 0 )); then
    am_tmux "${batch_args[@]}" >/dev/null 2>&1 || true
fi

# Stdout: clickable strip from the perspective of the arg session, only when
# explicitly requested. tmux invocations leave it empty so #() refreshes
# don't clobber the bar.
if $print_mode; then
    target_idx=-1
    for i in "${!S_NAME[@]}"; do
        if [[ "${S_NAME[$i]}" == "$current" ]]; then
            target_idx=$i
            break
        fi
    done
    if (( target_idx >= 0 )); then
        _build_strip "$target_idx" true false
        printf '%s\n' "$_STRIP"
    elif [[ -z "$current" ]]; then
        # No specific session requested — print first session's view so callers
        # still see meaningful output.
        _build_strip 0 true false
        printf '%s\n' "$_STRIP"
    fi
fi
