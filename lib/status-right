#!/usr/bin/env bash
# status-right - tmux status-right helper
# Shows all agent sessions as an indexed sidebar, ordered by tmux native order.
# Current session is highlighted in place. State is read from hook state files
# (fast file read) rather than full state detection.
# Called by tmux via:  #(/path/to/status-right <current_session>)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/utils.sh"
source "$SCRIPT_DIR/tmux.sh"
source "$SCRIPT_DIR/registry.sh"

current="${1:-}"
AM_STATE_DIR="${AM_STATE_DIR:-/tmp/am-state}"

# Build a short label for a session: directory basename, or session hash.
_label() {
    local session="$1"
    local dir branch label
    dir=$(registry_get_field "$session" directory 2>/dev/null || true)
    branch=$(registry_get_field "$session" branch 2>/dev/null || true)
    label="${dir:+$(dir_basename "$dir")}"
    [[ -n "$label" && -n "$branch" ]] && label+="/$branch"
    : "${label:=${session#am-}}"
    truncate "$label" 30
}

# Read state from hook state file (fast — just a file read).
# Falls back to empty string if file missing or stale.
_fast_state() {
    local session="$1"
    local state_file="$AM_STATE_DIR/$session"
    [[ -f "$state_file" ]] || return 0
    head -1 "$state_file" 2>/dev/null || true
}

# Get sessions in tmux native order
mapfile -t ordered < <(am_session_order)

[[ ${#ordered[@]} -eq 0 ]] && exit 0

# Build output in one pass
result=""
for i in "${!ordered[@]}"; do
    idx=$((i + 1))
    session="${ordered[$i]}"
    label=$(_label "$session")

    if [[ "$session" == "$current" ]]; then
        entry="#[fg=colour0,bg=colour14,bold]${idx}:${label}#[default]"
    else
        state=$(_fast_state "$session")
        case "$state" in
            waiting_permission|waiting_custom)
                entry="#[fg=colour214,bold]${idx}:! ${label}#[default]" ;;
            waiting_input)
                entry="#[fg=colour114]${idx}:> ${label}#[default]" ;;
            running)
                entry="#[fg=colour75]${idx}:~ ${label}#[default]" ;;
            *)
                entry="#[fg=colour240]${idx}:- ${label}#[default]" ;;
        esac
    fi

    [[ -n "$result" ]] && result+="  "
    result+="$entry"
done

# Write cache for pane-border-format (fast cat in border, no re-sourcing)
_sr_cache_dir="/tmp/am-sidebar"
[[ -d "$_sr_cache_dir" ]] || mkdir -p "$_sr_cache_dir"
[[ -n "$current" ]] && printf '%s' "$result" > "$_sr_cache_dir/$current"

echo "$result"
