#!/usr/bin/env bash
# status-right - tmux status-right helper
# Shows agent sessions waiting for user attention.
# Called by tmux via:  #(/path/to/status-right <current_session>)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/utils.sh"
source "$SCRIPT_DIR/config.sh"
source "$SCRIPT_DIR/tmux.sh"
source "$SCRIPT_DIR/registry.sh"
source "$SCRIPT_DIR/state.sh"

current="${1:-}"

# Build a short label for a session: directory basename, or session hash.
_label() {
    local session="$1"
    local dir branch label
    dir=$(registry_get_field "$session" directory 2>/dev/null || true)
    branch=$(registry_get_field "$session" branch 2>/dev/null || true)
    label="${dir:+$(dir_basename "$dir")}"
    [[ -n "$label" && -n "$branch" ]] && label+="/$branch"
    : "${label:=${session#am-}}"
    truncate "$label" 40
}

attention=()   # waiting_input, waiting_permission, waiting_custom
background=()  # idle, running

while IFS=' ' read -r session _; do
    [[ -z "$session" || "$session" == "$current" ]] && continue

    state=$(agent_get_state "$session" 2>/dev/null || true)

    case "$state" in
        waiting_permission|waiting_custom)
            attention+=("#[fg=colour214,bold]! $(_label "$session")#[default]")
            ;;
        waiting_input)
            background+=("#[fg=colour114]> $(_label "$session")#[default]")
            ;;
        running)
            background+=("#[fg=colour75]~ $(_label "$session")#[default]")
            ;;
        idle)
            background+=("#[fg=colour240]- $(_label "$session")#[default]")
            ;;
    esac
done < <(tmux_list_am_sessions_with_activity)

[[ ${#attention[@]} -eq 0 && ${#background[@]} -eq 0 ]] && exit 0

_join() {
    local result=""
    for item in "$@"; do
        [[ -n "$result" ]] && result+="  "
        result+="$item"
    done
    echo "$result"
}

attention_str=$( [[ ${#attention[@]} -gt 0 ]] && _join "${attention[@]}" || true)
background_str=$( [[ ${#background[@]} -gt 0 ]] && _join "${background[@]}" || true)

if [[ -n "$attention_str" && -n "$background_str" ]]; then
    echo "${attention_str}  #[fg=colour240]|#[default]  ${background_str}"
elif [[ -n "$attention_str" ]]; then
    echo "$attention_str"
else
    echo "$background_str"
fi
