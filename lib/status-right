#!/usr/bin/env bash
# status-right - tmux status-right helper
# Shows all agent sessions as an indexed sidebar in canonical am_session_order
# (creation time ascending). Current session is highlighted in place. State is
# read from hook state files (fast file read) rather than full state detection.
# Called by tmux via:  #(/path/to/status-right <current_session>)
#
# Produces two outputs:
# - stdout: the formatted string for status-right, with #[range=user|<sid>]
#   wrappers so MouseDown1Status can route clicks to switch-client.
# - @am_sidebar tmux session option: same content without range wrappers,
#   consumed by pane-border-format (which doesn't support #[range=...]).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/utils.sh"
source "$SCRIPT_DIR/tmux.sh"
source "$SCRIPT_DIR/registry.sh"
source "$SCRIPT_DIR/state.sh"

current="${1:-}"
AM_STATE_DIR="${AM_STATE_DIR:-/tmp/am-state}"

# Build a short label for a session: directory basename, or session hash.
_label() {
    local session="$1" dir="$2" branch="$3"
    local label
    label="${dir:+$(dir_basename "$dir")}"
    [[ -n "$label" && -n "$branch" ]] && label+="/$branch"
    : "${label:=${session#am-}}"
    truncate "$label" 30
}

# Read state from hook state file first, then fall back to the same lean
# detector used by `am list --json`. This keeps the common status refresh cheap
# while avoiding stale `-` idle indicators when /tmp hook state is missing.
_fast_state() {
    local session="$1" agent_type="$2" dir="$3"
    local state

    state=$(_state_from_hook "$session" 2>/dev/null || true)
    if [[ -n "$state" ]]; then
        echo "$state"
        return
    fi

    _agent_get_state_fast "$session" "$agent_type" "$dir" 2>/dev/null || true
}

# Get sessions in canonical order (creation time ascending)
mapfile -t ordered < <(am_session_order)

[[ ${#ordered[@]} -eq 0 ]] && exit 0

# Build both variants in one pass. `plain` (no #[range=...] wrappers) goes to
# the tmux session option consumed by pane-border-format. `clickable` (with
# user ranges) goes to stdout so status-right can route MouseDown1Status to the
# clicked session.
plain=""
clickable=""
for i in "${!ordered[@]}"; do
    idx=$((i + 1))
    session="${ordered[$i]}"
    fields=$(registry_get_fields "$session" directory branch agent_type 2>/dev/null || true)
    dir=""
    branch=""
    agent_type=""
    IFS='|' read -r dir branch agent_type <<< "$fields"
    label=$(_label "$session" "$dir" "$branch")

    if [[ "$session" == "$current" ]]; then
        entry="#[fg=colour0,bg=colour14,bold]${idx}:${label}#[default]"
    else
        state=$(_fast_state "$session" "$agent_type" "$dir")
        case "$state" in
            waiting_permission|waiting_custom)
                entry="#[fg=colour214,bold]${idx}:! ${label}#[default]" ;;
            waiting_input)
                entry="#[fg=colour114]${idx}:> ${label}#[default]" ;;
            running)
                entry="#[fg=colour75]${idx}:~ ${label}#[default]" ;;
            *)
                entry="#[fg=colour240]${idx}:- ${label}#[default]" ;;
        esac
    fi

    if [[ -n "$plain" ]]; then
        plain+="  "
        clickable+="  "
    fi
    plain+="$entry"
    clickable+="#[range=user|${session}]${entry}#[norange]"
done

# Update the plain variant for pane-border-format. Keeping this in a tmux option
# avoids #() command caching in pane-border-format, so refresh-client redraws it
# immediately after create/kill.
if [[ -n "$current" ]]; then
    am_tmux set-option -q -t "$current" @am_sidebar "$plain" >/dev/null 2>&1 || true
fi

# Emit the clickable variant on stdout for status-right to render.
echo "$clickable"
