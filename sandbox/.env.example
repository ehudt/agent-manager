# Anthropic API Key (optional - Claude Code can also use OAuth)
# Get one from: https://console.anthropic.com/account/keys
# If not set, Claude Code will use OAuth tokens from ~/.claude/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: forward host SSH agent socket into sandbox on container start
# Requires SSH_AUTH_SOCK to be set in your shell when running `am`.
# SB_FORWARD_SSH_AGENT=1
