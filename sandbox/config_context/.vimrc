set nocompatible
syntax on
filetype plugin indent on

set number
set mouse=a
set hlsearch
set incsearch
set ignorecase
set smartcase

set expandtab
set shiftwidth=4
set tabstop=4
set softtabstop=4

set autoindent
set backspace=indent,eol,start
set hidden
set ruler
set wildmenu

set nobackup
set nowritebackup
set noswapfile
