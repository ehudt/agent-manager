{
  "claude": [
    {"host": "~/.claude.json", "target": "~/.claude.json", "name": "claude-auth", "description": "Claude auth tokens"},
    {"host": "~/.claude", "target": "~/.claude", "name": "claude-data", "description": "Claude local data"}
  ],
  "ssh": [
    {"host": "~/.ssh", "target": "~/.ssh", "name": "ssh", "mode": "0700", "description": "SSH keys"}
  ],
  "git": [
    {"host": "~/.gitconfig", "target": "~/.gitconfig", "name": "gitconfig", "description": "Git identity and aliases"}
  ],
  "dotfiles": [
    {"host": "~/.zshrc", "target": "~/.zshrc", "name": "zshrc"},
    {"host": "~/.vimrc", "target": "~/.vimrc", "name": "vimrc"},
    {"host": "~/.tmux.conf", "target": "~/.tmux.conf", "name": "tmux-conf"}
  ],
  "codex": [
    {"host": "~/.codex/config.toml", "target": "~/.codex/config.toml", "name": "codex-config"},
    {"host": "~/.codex/auth.json", "target": "~/.codex/auth.json", "name": "codex-auth"}
  ]
}
